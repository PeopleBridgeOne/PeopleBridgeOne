<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --brand:#1a6b8a;--brand-dark:#114d65;--brand-light:#e6f3f8;--brand-mid:#4a9ab8;
  --purple-light:#EEEDFE;--purple-dark:#3C3489;
  --amber-light:#FAEEDA;--amber-dark:#633806;
  --coral-light:#FAECE7;--coral-dark:#712B13;
  --green-light:#EAF3DE;--green-dark:#27500A;
  --teal-light:#E1F5EE;--teal-dark:#085041;
  --text:#1a1a1a;--text-muted:#5c5c5c;--text-hint:#999;
  --bg:#fff;--bg-surface:#f7f6f3;--bg-page:#f2f0eb;
  --border:rgba(0,0,0,0.11);--border-med:rgba(0,0,0,0.18);
  --r:8px;--rl:12px;
}
@media(prefers-color-scheme:dark){
  :root{
    --text:#e8e6e0;--text-muted:#9c9a92;--text-hint:#666;
    --bg:#1c1c1a;--bg-surface:#242422;--bg-page:#161614;
    --border:rgba(255,255,255,0.1);--border-med:rgba(255,255,255,0.2);
    --brand-light:#0a2d3a;--purple-light:#26215C;
    --amber-light:#412402;--coral-light:#4A1B0C;
    --green-light:#173404;--teal-light:#04342C;
  }
}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--bg-page);color:var(--text);line-height:1.6;font-size:15px}
a{color:var(--brand)}
button{font-family:inherit}

/* SKIP LINK */
.skip-link{position:absolute;top:-100px;left:0;background:var(--brand);color:#fff;padding:8px 16px;border-radius:0 0 var(--r) 0;font-size:14px;font-weight:500;text-decoration:none;z-index:999;transition:top .1s}
.skip-link:focus{top:0}

/* NAV */
nav{background:var(--bg);border-bottom:0.5px solid var(--border);padding:0 24px;display:flex;align-items:center;justify-content:space-between;height:54px;position:sticky;top:0;z-index:100}
.logo{font-size:16px;font-weight:700;color:var(--text);text-decoration:none;letter-spacing:-0.5px;display:flex;align-items:center;gap:9px;cursor:pointer}
.logo-mark{width:28px;height:28px;background:var(--brand);border-radius:7px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.nav-desktop{display:flex;gap:2px}
.nav-link{padding:6px 13px;border-radius:var(--r);font-size:13px;color:var(--text-muted);cursor:pointer;border:none;background:none;text-decoration:none;transition:all .15s;white-space:nowrap}
.nav-link:hover,.nav-link.active{background:var(--bg-surface);color:var(--text)}
.nav-mobile-toggle{display:none;background:none;border:0.5px solid var(--border-med);border-radius:var(--r);padding:6px 10px;cursor:pointer;color:var(--text)}
.nav-mobile-menu{display:none;background:var(--bg);border-bottom:0.5px solid var(--border);padding:8px 16px 12px}
.nav-mobile-menu .nav-link{display:block;padding:10px 12px;width:100%}
@media(max-width:560px){
  .nav-desktop{display:none}
  .nav-mobile-toggle{display:block}
  .nav-mobile-menu.open{display:block}
}

/* PAGES */
.page{display:none}.page.active{display:block}

/* HERO */
.hero{background:var(--bg);border-bottom:0.5px solid var(--border);padding:44px 24px 36px}
.hero-inner{max-width:700px;margin:0 auto}
.hero-eyebrow{font-size:12px;font-weight:600;color:var(--brand);letter-spacing:0.8px;text-transform:uppercase;margin-bottom:12px}
.hero h1{font-size:30px;font-weight:700;line-height:1.2;margin-bottom:12px;letter-spacing:-0.5px}
.hero h1 em{font-style:normal;color:var(--brand)}
.hero-sub{font-size:15px;color:var(--text-muted);max-width:500px;margin-bottom:26px;line-height:1.65}
.hero-badges{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:24px}
.hero-badge{font-size:12px;padding:4px 12px;border-radius:99px;border:0.5px solid var(--border-med);color:var(--text-muted);background:var(--bg-surface)}

/* POSTCODE WIDGET */
.postcode-widget{background:var(--bg-surface);border:0.5px solid var(--border-med);border-radius:var(--rl);padding:20px;max-width:520px}
.postcode-widget label{font-size:13px;font-weight:600;color:var(--text);margin-bottom:8px;display:block}
.input-row{display:flex;gap:8px;flex-wrap:wrap}
.input-row input{flex:1;min-width:140px;height:40px;border:0.5px solid var(--border-med);border-radius:var(--r);padding:0 14px;font-size:14px;background:var(--bg);color:var(--text)}
.input-row input:focus{outline:none;border-color:var(--brand);box-shadow:0 0 0 3px rgba(26,107,138,.12)}
.btn{height:40px;padding:0 18px;border-radius:var(--r);font-size:14px;font-weight:500;cursor:pointer;border:none;transition:all .15s;display:inline-flex;align-items:center;gap:6px;text-decoration:none}
.btn-primary{background:var(--brand);color:#fff}.btn-primary:hover{background:var(--brand-dark)}
.btn-outline{background:var(--bg);color:var(--text);border:0.5px solid var(--border-med)}.btn-outline:hover{background:var(--bg-surface)}
.btn-sm{height:34px;font-size:13px;padding:0 14px}
#mp-result{margin-top:14px;font-size:13px;min-height:18px}
.mp-card{background:var(--bg);border:0.5px solid var(--border);border-radius:var(--r);padding:12px 14px;margin-top:10px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap}
.mp-card-name{font-weight:600;color:var(--text);font-size:13px;margin-bottom:2px}
.mp-card-area{color:var(--text-muted);font-size:12px}

/* LAYOUT */
.container{max-width:780px;margin:0 auto;padding:30px 24px}
.sec-label{font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.7px;margin-bottom:14px}
.divider{height:0.5px;background:var(--border);margin:28px 0}

/* PILLS */
.pill-row{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:18px}
.pill{font-size:13px;padding:5px 14px;border-radius:99px;border:0.5px solid var(--border-med);color:var(--text-muted);cursor:pointer;background:var(--bg);transition:all .1s}
.pill.active,.pill:hover{background:var(--brand-light);color:var(--brand-dark);border-color:var(--brand)}

/* CARDS */
.cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:12px}
.card{background:var(--bg);border:0.5px solid var(--border);border-radius:var(--rl);padding:16px;cursor:pointer;transition:border-color .15s,transform .1s}
.card:hover{border-color:var(--border-med);transform:translateY(-1px)}
.tag{display:inline-block;font-size:11px;font-weight:700;padding:3px 9px;border-radius:var(--r);margin-bottom:8px}
.tag-h{background:var(--teal-light);color:var(--teal-dark)}
.tag-b{background:var(--purple-light);color:var(--purple-dark)}
.tag-v{background:var(--amber-light);color:var(--amber-dark)}
.tag-n{background:var(--coral-light);color:var(--coral-dark)}
.tag-e{background:var(--green-light);color:var(--green-dark)}
.tag-r{background:var(--brand-light);color:var(--brand-dark)}
.card-title{font-size:14px;font-weight:600;margin-bottom:5px;line-height:1.35}
.card-desc{font-size:13px;color:var(--text-muted);line-height:1.5}
.card-soon{opacity:.55;cursor:default}.card-soon:hover{transform:none;border-color:var(--border)}
.soon-badge{font-size:11px;color:var(--text-hint);margin-top:8px}

/* ACTION GRID */
.action-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:12px}
.action-card{background:var(--bg-surface);border:0.5px solid var(--border);border-radius:var(--rl);padding:16px;cursor:pointer;transition:border-color .15s}
.action-card:hover{border-color:var(--border-med)}
.action-icon{width:30px;height:30px;border-radius:7px;margin-bottom:10px;display:flex;align-items:center;justify-content:center}
.action-title{font-size:14px;font-weight:600;margin-bottom:4px}
.action-desc{font-size:13px;color:var(--text-muted);line-height:1.5}

/* STATS — honest version */
.stat-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:12px}
.stat{background:var(--bg-surface);border-radius:var(--r);padding:16px;text-align:center}
.stat-num{font-size:24px;font-weight:700;color:var(--text)}
.stat-lbl{font-size:12px;color:var(--text-muted);margin-top:3px}
.stat-note{font-size:11px;color:var(--text-hint);margin-top:6px;font-style:italic}
.launch-banner{background:var(--brand-light);border:0.5px solid var(--brand-mid);border-radius:var(--r);padding:10px 14px;font-size:13px;color:var(--brand-dark);margin-bottom:16px;display:flex;align-items:center;gap:8px}
.launch-dot{width:8px;height:8px;border-radius:50%;background:var(--brand);flex-shrink:0}

/* NETLIFY SIGNUP FORM */
.signup-strip{background:var(--brand-light);border:0.5px solid var(--brand-mid);border-radius:var(--rl);padding:20px 22px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap}
.signup-text h3{font-size:15px;font-weight:600;color:var(--brand-dark);margin-bottom:3px}
.signup-text p{font-size:13px;color:var(--brand-dark);opacity:.8}
.signup-form-inner{display:flex;gap:8px;flex-wrap:wrap}
.signup-form-inner input[type="email"]{height:38px;border:0.5px solid var(--brand);border-radius:var(--r);padding:0 13px;font-size:13px;background:var(--bg);color:var(--text);width:220px}
.signup-form-inner input[type="email"]:focus{outline:none;box-shadow:0 0 0 3px rgba(26,107,138,.15);border-color:var(--brand)}
.honeypot{display:none}

/* EXPLAINER */
.back-btn{display:inline-flex;align-items:center;gap:5px;font-size:13px;color:var(--text-muted);cursor:pointer;border:none;background:none;padding:0;margin-bottom:20px}
.back-btn:hover{color:var(--text)}
.explainer-wrap{max-width:640px}
.explainer h2{font-size:23px;font-weight:700;margin-bottom:6px;line-height:1.25;letter-spacing:-.3px}
.explainer .meta{font-size:13px;color:var(--text-muted);margin-bottom:14px}
.badge-row{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:22px}
.ebadge{font-size:12px;padding:3px 10px;border-radius:99px;border:0.5px solid var(--border);color:var(--text-muted)}
.explainer p{font-size:15px;line-height:1.75;margin-bottom:14px}
.explainer strong{font-weight:600}
.highlight{background:var(--brand-light);border-left:3px solid var(--brand);padding:14px 16px;margin:18px 0;border-radius:0 var(--r) var(--r) 0}
.highlight p{margin:0;font-size:14px;color:var(--brand-dark)}
.key-facts{background:var(--bg-surface);border-radius:var(--rl);padding:16px 18px;margin:18px 0}
.key-facts h4{font-size:12px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px}
.key-fact{display:flex;gap:10px;margin-bottom:8px;font-size:14px}
.key-fact-icon{color:var(--brand);font-weight:700;flex-shrink:0;margin-top:1px}
.cta-strip{margin-top:26px;padding-top:20px;border-top:0.5px solid var(--border)}
.cta-strip p{font-size:14px;font-weight:600;margin-bottom:10px}

/* LETTER TOOL */
.letter-wrap{display:grid;grid-template-columns:1fr 1fr;gap:28px;align-items:start}
@media(max-width:580px){.letter-wrap{grid-template-columns:1fr}}
.letter-tool label{display:block;font-size:14px;font-weight:500;margin-bottom:5px;margin-top:16px}
.letter-tool label:first-of-type{margin-top:0}
.letter-tool input,.letter-tool select,.letter-tool textarea{width:100%;border:0.5px solid var(--border-med);border-radius:var(--r);padding:9px 13px;font-size:14px;background:var(--bg);color:var(--text)}
.letter-tool input:focus,.letter-tool select:focus,.letter-tool textarea:focus{outline:none;border-color:var(--brand);box-shadow:0 0 0 3px rgba(26,107,138,.1)}
.letter-tool textarea{min-height:90px;resize:vertical;line-height:1.6}
.letter-preview-wrap{position:sticky;top:74px}
.letter-preview-label{font-size:12px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.6px;margin-bottom:10px}
.letter-preview{background:var(--bg);border:0.5px solid var(--border-med);border-radius:var(--rl);padding:20px;font-size:14px;line-height:1.8;white-space:pre-wrap;min-height:200px;color:var(--text)}
.letter-placeholder{color:var(--text-hint);font-size:14px;font-style:italic}
.btn-row{display:flex;gap:8px;flex-wrap:wrap;margin-top:12px}
.copy-confirm{font-size:13px;color:var(--brand-dark);margin-top:8px;font-weight:500;display:none}
.steps .step{display:flex;gap:12px;margin-bottom:14px}
.step-num{width:22px;height:22px;border-radius:50%;background:var(--brand);color:#fff;font-size:12px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px}
.step-body{font-size:14px;color:var(--text-muted);line-height:1.5}
.step-body strong{color:var(--text);font-weight:600}

/* SUGGEST FORM */
.suggest-form{background:var(--bg-surface);border:0.5px solid var(--border);border-radius:var(--rl);padding:20px;margin-top:28px;max-width:520px}
.suggest-form h3{font-size:15px;font-weight:600;margin-bottom:5px}
.suggest-form p{font-size:13px;color:var(--text-muted);margin-bottom:14px}
.suggest-form input,.suggest-form textarea{width:100%;border:0.5px solid var(--border-med);border-radius:var(--r);padding:9px 13px;font-size:14px;background:var(--bg);color:var(--text);margin-bottom:10px}
.suggest-form input:focus,.suggest-form textarea:focus{outline:none;border-color:var(--brand);box-shadow:0 0 0 3px rgba(26,107,138,.1)}
.suggest-form textarea{min-height:60px;resize:vertical}

/* ABOUT */
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin:20px 0}
@media(max-width:520px){.about-grid{grid-template-columns:1fr}}
.about-card{background:var(--bg-surface);border-radius:var(--rl);padding:16px 18px;border:0.5px solid var(--border)}
.about-card h4{font-size:14px;font-weight:600;margin-bottom:6px}
.about-card p{font-size:13px;color:var(--text-muted);line-height:1.6}

/* FOOTER */
footer{background:var(--bg);border-top:0.5px solid var(--border);padding:30px 24px;margin-top:48px}
.footer-inner{max-width:780px;margin:0 auto}
.footer-top{display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:16px;margin-bottom:20px}
.footer-logo{font-size:15px;font-weight:700;color:var(--text);display:flex;align-items:center;gap:7px}
.footer-logo .fmark{width:22px;height:22px;background:var(--brand);border-radius:5px;display:flex;align-items:center;justify-content:center}
.footer-links{display:flex;gap:16px;flex-wrap:wrap}
.footer-link{font-size:13px;color:var(--text-muted);text-decoration:none}.footer-link:hover{color:var(--text)}
.footer-bottom{border-top:0.5px solid var(--border);padding-top:16px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px}
.footer-note{font-size:12px;color:var(--text-hint)}
</style>
</head>
