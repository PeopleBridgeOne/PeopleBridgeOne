<main id="main">

<!-- HOME -->
<div class="page active" id="page-home">
  <div class="hero">
    <div class="hero-inner">
      <div class="hero-eyebrow">Free · Non-partisan · Plain English</div>
      <h1>Democracy works better<br>when <em>everyone</em> can take part</h1>
      <p class="hero-sub">We translate UK policy into plain English, tell you how it affects your life, and give you simple tools to make your voice heard — whoever you are, wherever you live.</p>
      <div class="hero-badges">
        <span class="hero-badge">No jargon</span>
        <span class="hero-badge">Always free</span>
        <span class="hero-badge">Non-partisan</span>
        <span class="hero-badge">Updated regularly</span>
      </div>
      <div class="postcode-widget">
        <label for="postcode">Find your MP and local information</label>
        <div class="input-row">
          <input type="text" id="postcode" placeholder="Your postcode, e.g. B15 2TT" maxlength="8" autocomplete="postal-code" />
          <button class="btn btn-primary" onclick="lookupPostcode()">Search</button>
        </div>
        <div id="mp-result" aria-live="polite"></div>
      </div>
    </div>
  </div>

  <div class="container">
    <div class="sec-label">Latest explainers</div>
    <div class="cards" style="margin-bottom:32px">
      <div class="card" onclick="openExplainer('renters')" tabindex="0" role="button" aria-label="Read: Renters Rights Bill">
        <span class="tag tag-h">Housing</span>
        <div class="card-title">Renters' Rights Bill: what changes for you</div>
        <div class="card-desc">No-fault evictions abolished. What your landlord can and can't do now.</div>
      </div>
      <div class="card" onclick="openExplainer('uc')" tabindex="0" role="button">
        <span class="tag tag-b">Benefits</span>
        <div class="card-title">Universal Credit cuts explained</div>
        <div class="card-desc">What the 2025 reforms mean for your payments.</div>
      </div>
      <div class="card" onclick="openExplainer('voterid')" tabindex="0" role="button">
        <span class="tag tag-v">Voting</span>
        <div class="card-title">Voter ID: get free photo ID in 5 minutes</div>
        <div class="card-desc">A free Voter Authority Certificate is available to everyone.</div>
      </div>
      <div class="card" onclick="openExplainer('nhs')" tabindex="0" role="button">
        <span class="tag tag-n">NHS</span>
        <div class="card-title">NHS waiting lists: know your rights</div>
        <div class="card-desc">You have legal rights around waiting times. Here's how to use them.</div>
      </div>
    </div>

    <div class="divider"></div>
    <div class="sec-label">Take action</div>
    <div class="action-grid" style="margin-bottom:32px">
      <div class="action-card" onclick="showPage('act')" tabindex="0" role="button">
        <div class="action-icon" style="background:var(--brand-light)">
          <svg width="16" height="16" fill="none" viewBox="0 0 16 16" aria-hidden="true"><rect x="2" y="3" width="12" height="10" rx="1.5" stroke="#114d65" stroke-width="1.3"/><path d="M2 5.5L8 9.5L14 5.5" stroke="#114d65" stroke-width="1.3"/></svg>
        </div>
        <div class="action-title">Write to your MP</div>
        <p class="action-desc">We draft a professional letter in seconds. You copy and send.</p>
      </div>
      <div class="action-card" onclick="window.open('https://www.gov.uk/register-to-vote','_blank')" tabindex="0" role="button">
        <div class="action-icon" style="background:var(--purple-light)">
          <svg width="16" height="16" fill="none" viewBox="0 0 16 16" aria-hidden="true"><circle cx="8" cy="8" r="5.5" stroke="#3C3489" stroke-width="1.3"/><path d="M5.5 8.2L7.2 10L10.5 6.5" stroke="#3C3489" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="action-title">Register to vote</div>
