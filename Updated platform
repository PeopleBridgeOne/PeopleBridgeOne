  document.getElementById('page-' + p).classList.add('active');
  const navEl = document.getElementById('nav-' + p);
  if (navEl) navEl.classList.add('active');
  window.scrollTo(0, 0);
  return false;
}

function toggleMobileNav() {
  const menu = document.getElementById('mobile-menu');
  const toggle = document.getElementById('mobile-toggle');
  const open = menu.classList.toggle('open');
  toggle.setAttribute('aria-expanded', open);
}
function closeMobileNav() {
  document.getElementById('mobile-menu').classList.remove('open');
  document.getElementById('mobile-toggle').setAttribute('aria-expanded','false');
}

function filterCards(cat, el) {
  document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
  el.classList.add('active');
  document.querySelectorAll('#explainer-cards .card').forEach(c => {
    c.style.display = (cat === 'all' || c.dataset.cat === cat) ? '' : 'none';
  });
}

function openExplainer(id) {
  const e = EXPLAINERS[id];
  if (!e) return;
  const badges = e.badges.map(b => `<span class="ebadge">${b}</span>`).join('');
  const facts = e.keyFacts.map(f => `<div class="key-fact"><div class="key-fact-icon" aria-hidden="true">→</div><div>${f}</div></div>`).join('');
  document.getElementById('explainer-content').innerHTML = `
    <span class="tag ${e.tag}">${e.tagLabel}</span>
    <h2 style="margin-top:8px">${e.title}</h2>
    <div class="meta">${e.updated}</div>
    <div class="badge-row">${badges}</div>
    <div class="key-facts"><h4>Key facts</h4>${facts}</div>
    ${e.content}
    <div class="cta-strip">
      <p>Want to do something about this?</p>
      <div style="display:flex;gap:10px;flex-wrap:wrap">
        <button class="btn btn-primary" onclick="showPage('act')">Write to your MP</button>
        <button class="btn btn-outline" onclick="closeExplainer()">More explainers</button>
      </div>
    </div>`;
  document.getElementById('explainer-list').style.display = 'none';
  document.getElementById('explainer-detail').style.display = 'block';
  window.scrollTo(0, 0);
}

function closeExplainer() {
  document.getElementById('explainer-list').style.display = '';
  document.getElementById('explainer-detail').style.display = 'none';
}

function lookupPostcode() {
  const pc = document.getElementById('postcode').value.trim();
  const r = document.getElementById('mp-result');
  if (pc.replace(/\s/g,'').length < 5) { r.innerHTML = ''; return; }
  r.innerHTML = '<span style="color:var(--text-muted)">Looking up...</span>';
  fetch(`https://api.postcodes.io/postcodes/${encodeURIComponent(pc)}`)
    .then(res => res.json())
    .then(data => {
      if (data.status === 200) {
        const c = data.result.parliamentary_constituency_2024 || data.result.parliamentary_constituency || data.result.admin_district || 'your area';
        r.innerHTML = `<div class="mp-card">
          <div><div class="mp-card-name">${c}</div><div class="mp-card-area">Find your MP by name at members.parliament.uk</div></div>
          <a class="btn btn-primary btn-sm" href="https://members.parliament.uk/members/commons" target="_blank" rel="noopener">Find my MP</a>
        </div>`;
      } else {
        r.innerHTML = '<span style="color:var(--text-muted)">Postcode not found — check the format, e.g. B15 2TT</span>';
      }
    })
    .catch(() => {
      r.innerHTML = 'Find your MP at <a href="https://members.parliament.uk/members/commons" target="_blank" rel="noopener">members.parliament.uk</a>.';
    });
}

function lookupMP() {
  const pc = document.getElementById('ltr-postcode').value.trim();
  const out = document.getElementById('ltr-mp-name');
  if (pc.replace(/\s/g,'').length < 5) { out.textContent = ''; currentConstituency = ''; return; }
  fetch(`https://api.postcodes.io/postcodes/${encodeURIComponent(pc)}`)
    .then(res => res.json())
    .then(data => {
      if (data.status === 200) {
        currentConstituency = data.result.parliamentary_constituency_2024 || data.result.parliamentary_constituency || '';
        out.innerHTML = currentConstituency
          ? `<span style="color:var(--brand-dark)">Constituency: <strong>${currentConstituency}</strong></span> — <a href="https://members.parliament.uk/members/commons" target="_blank" rel="noopener" style="font-size:13px">look up your MP's name</a>`
          : '';
        updateLetter();
      }
    }).catch(() => {});
}

function updateLetter() {
  const name = document.getElementById('ltr-name').value.trim();
  const issue = document.getElementById('ltr-issue').value;
  const detail = document.getElementById('ltr-detail').value.trim();
  const postcode = document.getElementById('ltr-postcode').value.trim().toUpperCase();
  const txt = document.getElementById('letter-text');
  const copyBtn = document.getElementById('copy-btn');
  const mpLink = document.getElementById('mp-link');

  if (!name || !issue) {
    txt.innerHTML = '<span class="letter-placeholder">Fill in your name and choose an issue to generate your letter...</span>';
    copyBtn.style.display = 'none'; mpLink.style.display = 'none';
    return;
  }
  const loc = postcode ? ` in ${postcode}` : '';
  const salutation = currentConstituency ? `Dear MP for ${currentConstituency},` : 'Dear [your MP\'s name],';
  const body = ISSUE_TEXT[issue] || ISSUE_TEXT.custom;
  const detailPara = detail ? `\n\nIn my own experience: ${detail}` : '';
  txt.textContent = `${salutation}\n\nI am writing as one of your constituents${loc}. ${body}${detailPara}\n\nI would welcome the opportunity to understand your position on this issue and what steps you are taking to support affected constituents. I would be grateful for a response at your earliest convenience.\n\nYours sincerely,\n${name}`;
  copyBtn.style.display = 'inline-flex';
  mpLink.style.display = 'inline-flex';
}

function copyLetter() {
  const txt = document.getElementById('letter-text').textContent;
  navigator.clipboard.writeText(txt).then(() => {
    letterCount++;
    localStorage.setItem('ba_letters', letterCount);
    updateStatDisplay();
    const c = document.getElementById('copy-confirm');
    c.style.display = 'block';
    setTimeout(() => c.style.display = 'none', 5000);
  });
}

function handleNetlifySignup(e, thanksId, formId) {
  e.preventDefault();
  const form = e.target;
  fetch('/', { method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body: new URLSearchParams(new FormData(form)).toString() })
    .then(() => {
      document.getElementById(formId).style.display = 'none';
      document.getElementById(thanksId).style.display = 'block';
    }).catch(() => {
      document.getElementById(thanksId).style.display = 'block';
      document.getElementById(thanksId).textContent = "You're signed up.";
    });
}

